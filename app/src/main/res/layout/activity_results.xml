<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/resultsTitleTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scam Analysis Results"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Risk Level"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/riskLevelTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="High"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scam Type"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/scamTypeTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bank Impersonation"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Red Flags Detected"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/redFlagsTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Urgent language&#10;• Suspicious link&#10;• Requests account verification"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Safe Action Guidance"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/safeGuidanceTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Do not click the link. Contact your bank through the official app or website."
            android:padding="12dp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/backButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back" />

    </LinearLayout>
</ScrollView>