<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/bg_button_secondary"
                android:contentDescription="Back"
                android:scaleType="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Analysis"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginStart="14dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Risk Verdict"
            android:textSize="13sp"
            android:textColor="@color/text_muted"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/riskBadgeContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_risk_high"
            android:padding="22dp"
            android:layout_marginBottom="22dp">

            <TextView
                android:id="@+id/riskLevelTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="High"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="@color/risk_high"
                android:letterSpacing="0.02" />

            <TextView
                android:id="@+id/scamTypeTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bank impersonation scam"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_source"
                    android:contentDescription="Original message" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Original Message"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/originalMessageTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="4dp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_alert"
                    android:contentDescription="Red flags" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Red Flags Detected"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/redFlagsTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Uses urgent or threatening language\n• Contains a link or web address\n• Requests verification or personal details"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="6dp" />
        </LinearLayout>

        <!-- AI Explanation card: populated by Gemma once integrated -->
        <LinearLayout
            android:id="@+id/aiExplanationContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <!-- Shield icon signals this section is AI-powered -->
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_shield"
                    android:contentDescription="AI explanation" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Explanation"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <!-- Loading indicator shown while Gemma processes -->
            <ProgressBar
                android:id="@+id/aiLoadingSpinner"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:indeterminateTint="@color/accent"
                android:visibility="gone" />

            <!-- AI response text, placeholder for now -->
            <TextView
                android:id="@+id/aiExplanationTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AI explanation will appear here once Gemma is integrated."
                android:textSize="14sp"
                android:textColor="@color/text_muted"
                android:fontFamily="sans-serif"
                android:lineSpacingExtra="5dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_check"
                    android:contentDescription="Safe guidance" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Safe Action Guidance"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/safeGuidanceTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Do not click the link. Contact your bank through the official app or website."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="6dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_source"
                    android:contentDescription="Source" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Message Source"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/sourceTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SMS"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_tag"
                    android:contentDescription="Selected concerns" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selected Concerns"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/concernsTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Urgent, Contains Link"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_disclaimer"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_info"
                    android:contentDescription="Safety disclaimer" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Safety Disclaimer"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/risk_medium"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/disclaimerTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ScamGuard provides risk-based guidance only. It does not guarantee that a message is a scam and should not replace official legal, financial, or security advice."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>