<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/resultsTitleTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scam Analysis Results"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Review the message carefully before taking any action."
            android:textSize="15sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:strokeColor="@color/outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Message Source"
                    android:textStyle="bold"
                    android:textColor="@color/accent"
                    android:textSize="13sp"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/sourceTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SMS"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="8dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bg_divider"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selected Concerns"
                    android:textStyle="bold"
                    android:textColor="@color/accent"
                    android:textSize="13sp"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/concernsTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Urgent, Contains Link"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:strokeColor="@color/outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Risk Assessment"
                    android:textStyle="bold"
                    android:textColor="@color/accent"
                    android:textSize="13sp"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/riskLevelTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="High"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/risk_high"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/scamTypeTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bank Impersonation"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:strokeColor="@color/outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Red Flags Detected"
                    android:textStyle="bold"
                    android:textColor="@color/accent"
                    android:textSize="13sp"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/redFlagsTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Urgent language&#10;• Suspicious link&#10;• Requests account verification"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/accent_soft"
            app:strokeColor="@color/accent"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Safe Action Guidance"
                    android:textStyle="bold"
                    android:textColor="@color/accent"
                    android:textSize="13sp"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/safeGuidanceTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Do not click the link. Contact your bank through the official app or website."
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/bg_base"
            app:strokeColor="@color/bg_divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Safety Disclaimer"
                    android:textStyle="bold"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/disclaimerTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ScamGuard provides risk-based guidance only. It does not guarantee that a message is a scam and should not replace official legal, financial, or security advice."
                    android:textSize="13sp"
                    android:textColor="@color/text_muted"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/backButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Done"
            android:textColor="@color/accent"
            app:strokeColor="@color/accent" />

    </LinearLayout>
</ScrollView>