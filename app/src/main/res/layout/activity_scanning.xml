<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_gravity="center">

        <!-- Dual spinning rings with AI icon in centre -->
        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center"
            android:layout_marginBottom="32dp">

            <!-- Outer ring spins clockwise -->
            <ImageView
                android:id="@+id/outerRing"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:src="@drawable/ring_outer"
                android:layout_gravity="center" />

            <!-- Inner ring spins counter-clockwise -->
            <ImageView
                android:id="@+id/innerRing"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ring_inner"
                android:layout_gravity="center" />

            <!-- Shield icon at centre -->
            <ImageView
                android:id="@+id/aiIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_shield"
                android:layout_gravity="center"
                android:alpha="0"
                android:scaleX="0.7"
                android:scaleY="0.7"
                android:contentDescription="ScamGuard" />
        </FrameLayout>

        <!-- Main step text -->
        <TextView
            android:id="@+id/scanningStepText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reading message structure..."
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <!-- Typing dots subtitle -->
        <TextView
            android:id="@+id/scanningSubText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analysing..."
            android:textSize="13sp"
            android:textColor="@color/text_muted"
            android:layout_marginTop="8dp" />

        <!-- Progress pills -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp">

            <View
                android:id="@+id/dot1"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot"
                android:layout_marginEnd="12dp" />

            <View
                android:id="@+id/dot2"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot"
                android:layout_marginEnd="12dp" />

            <View
                android:id="@+id/dot3"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot"
                android:layout_marginEnd="12dp" />

            <View
                android:id="@+id/dot4"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>