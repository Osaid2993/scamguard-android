<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_base">

    <!-- Sticky top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        android:background="@color/bg_base"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@drawable/bg_button_secondary"
            android:contentDescription="Back"
            android:scaleType="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Scan History"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginStart="14dp" />

        <TextView
            android:id="@+id/clearButton"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Clear"
            android:textColor="@color/risk_high"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/bg_button_secondary"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Summary count cards -->
    <LinearLayout
        android:id="@+id/summaryContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_risk_high"
            android:padding="12dp"
            android:layout_marginEnd="6dp">

            <TextView
                android:id="@+id/countHigh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/risk_high"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HIGH"
                android:textSize="10sp"
                android:textColor="@color/text_muted"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_risk_medium"
            android:padding="12dp"
            android:layout_marginEnd="6dp">

            <TextView
                android:id="@+id/countMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/risk_medium"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MEDIUM"
                android:textSize="10sp"
                android:textColor="@color/text_muted"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_risk_low"
            android:padding="12dp"
            android:layout_marginEnd="6dp">

            <TextView
                android:id="@+id/countLow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/risk_low"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOW"
                android:textSize="10sp"
                android:textColor="@color/text_muted"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_risk_minimal"
            android:padding="12dp">

            <TextView
                android:id="@+id/countMinimal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/risk_minimal"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MINIMAL"
                android:textSize="10sp"
                android:textColor="@color/text_muted"
                android:letterSpacing="0.05" />
        </LinearLayout>

    </LinearLayout>

    <!-- Filter chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/filterAll"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="All"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="@color/bg_base"
                android:background="@drawable/bg_button_primary"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/filterHigh"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="High"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_button_secondary"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/filterMedium"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Medium"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_button_secondary"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/filterLow"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Low"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_button_secondary"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/filterMinimal"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Minimal"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_button_secondary"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Empty state -->
    <TextView
        android:id="@+id/emptyStateText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No scans yet. Analyse a message to see it here."
        android:textSize="14sp"
        android:textColor="@color/text_muted"
        android:gravity="center"
        android:paddingTop="60dp"
        android:visibility="gone" />

    <!-- History list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/historyRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="4dp"
        android:paddingBottom="24dp"
        android:clipToPadding="false" />

</LinearLayout>