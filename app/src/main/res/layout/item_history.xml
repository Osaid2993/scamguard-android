<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_card"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:layout_marginStart="22dp"
    android:layout_marginEnd="22dp"
    android:gravity="center_vertical">

    <!-- Risk icon -->
    <ImageView
        android:id="@+id/historyRiskIcon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_risk_high"
        android:contentDescription="Risk icon"
        android:layout_marginEnd="14dp" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Top row: risk badge and timestamp -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/historyRiskLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="High"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/risk_high"
                android:background="@drawable/bg_risk_high"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/historyTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2 min ago"
                android:textSize="12sp"
                android:textColor="@color/text_muted" />
        </LinearLayout>

        <!-- Scam type -->
        <TextView
            android:id="@+id/historyScamType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bank impersonation scam"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginBottom="2dp" />

        <!-- Message snippet -->
        <TextView
            android:id="@+id/historySnippet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="URGENT: Your bank account will be suspended..."
            android:textSize="13sp"
            android:textColor="@color/text_muted"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="4dp" />

        <!-- Source -->
        <TextView
            android:id="@+id/historySource"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SMS"
            android:textSize="12sp"
            android:textColor="@color/text_muted"
            android:visibility="gone" />

        <!-- View details indicator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="View details ›"
                android:textSize="11sp"
                android:textColor="@color/accent"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_button_secondary"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>