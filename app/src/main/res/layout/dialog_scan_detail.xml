<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top accent bar that matches the risk colour -->
        <View
            android:id="@+id/accentBar"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="@color/risk_high" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header row: icon + verdict + confidence -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/detailRiskIcon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_risk_high"
                    android:contentDescription="Risk icon"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/detailRiskLevel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="High"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/risk_high"
                            android:background="@drawable/bg_risk_high"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp" />

                        <TextView
                            android:id="@+id/detailTimestamp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2 min ago"
                            android:textSize="12sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginStart="10dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/detailScamType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bank impersonation scam"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Confidence percentage -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/detailConfidence"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="95%"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/risk_high"
                        android:fontFamily="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CONFIDENCE"
                        android:textSize="9sp"
                        android:textColor="@color/text_muted"
                        android:letterSpacing="0.05" />
                </LinearLayout>
            </LinearLayout>

            <!-- Full message section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MESSAGE"
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/detailFullMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Message content here..."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="monospace"
                android:lineSpacingExtra="4dp"
                android:background="@drawable/bg_input"
                android:padding="14dp"
                android:layout_marginBottom="16dp" />

            <!-- Risk level bar -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RISK LEVEL"
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@drawable/bg_confidence_track"
                android:layout_marginBottom="16dp">

                <View
                    android:id="@+id/detailConfidenceBar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@color/risk_high" />
            </FrameLayout>

            <!-- Red flags section -->
            <TextView
                android:id="@+id/detailRedFlagsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RED FLAGS"
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/detailRedFlags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Red flags here..."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="5dp"
                android:layout_marginBottom="20dp" />

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/detailShareButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Share"
                    android:textColor="@color/accent"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:gravity="center"
                    android:background="@drawable/bg_button_secondary"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/detailReportButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Report"
                    android:textColor="@color/risk_high"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:gravity="center"
                    android:background="@drawable/bg_button_secondary"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/detailCloseButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Close"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:gravity="center"
                    android:background="@drawable/bg_button_secondary"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>