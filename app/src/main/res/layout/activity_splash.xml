<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:orientation="vertical"
    android:gravity="center">

    <ImageView
        android:id="@+id/splashShield"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_shield_splash"
        android:alpha="0"
        android:scaleX="0.7"
        android:scaleY="0.7"
        android:contentDescription="ScamGuard shield" />

    <TextView
        android:id="@+id/splashTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ScamGuard"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:alpha="0"
        android:layout_marginTop="20dp" />

    <TextView
        android:id="@+id/splashTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Private on-device scam analysis"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:alpha="0"
        android:layout_marginTop="8dp" />

</LinearLayout>