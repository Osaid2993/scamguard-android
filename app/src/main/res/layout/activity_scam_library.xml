<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- Top bar with back button and title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/bg_button_secondary"
                android:contentDescription="Back"
                android:scaleType="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scam Library"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginStart="14dp" />
        </LinearLayout>

        <!-- Subtitle explaining the screen -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Learn how common scams work. Tap 'Try Example' to see how ScamGuard detects each pattern."
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="22dp" />

        <!-- Card 1: Bank impersonation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bank Impersonation"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pretends to be your bank and pressures you to verify your identity or share account details urgently."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="3dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp" />

            <!-- Try Example button -->
            <TextView
                android:id="@+id/tryBankExample"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Try Example"
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:gravity="center"
                android:background="@drawable/bg_button_secondary"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Card 2: Fake delivery -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fake Delivery"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Claims a parcel could not be delivered and asks you to pay a small fee or click a tracking link."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="3dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/tryDeliveryExample"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Try Example"
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:gravity="center"
                android:background="@drawable/bg_button_secondary"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Card 3: Government or tax -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Government or Tax"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Impersonates the ATO, Centrelink, or Medicare and threatens fines or legal action to pressure immediate payment."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="3dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/tryGovernmentExample"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Try Example"
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:gravity="center"
                android:background="@drawable/bg_button_secondary"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Card 4: Prize or reward -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prize or Reward"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tells you that you have won a prize, gift card, or reward and asks for personal details or a fee to claim it."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="3dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/tryPrizeExample"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Try Example"
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:gravity="center"
                android:background="@drawable/bg_button_secondary"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Card 5: OTP or verification code -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OTP or Verification Code"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Asks you to share a one-time password or verification code, often while pretending to be a support agent."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="3dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/tryOtpExample"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Try Example"
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:gravity="center"
                android:background="@drawable/bg_button_secondary"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Card 6: Marketplace -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Marketplace Scam"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Targets buyers or sellers on platforms like Facebook Marketplace or Gumtree with fake payment links or overpayment tricks."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="3dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/tryMarketplaceExample"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Try Example"
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:gravity="center"
                android:background="@drawable/bg_button_secondary"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>