<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.ScamGuard" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorOnPrimary">@color/bg_base</item>
        <item name="colorPrimaryContainer">@color/accent_soft</item>
        <item name="colorOnPrimaryContainer">@color/accent</item>
        <item name="colorSecondary">@color/accent_dim</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/bg_base</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/outline</item>
        <item name="android:statusBarColor">@color/bg_base</item>
        <item name="android:navigationBarColor">@color/bg_base</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Theme.ScamGuard.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_base</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_shield_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.ScamGuard</item>
    </style>

</resources>